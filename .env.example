# RAJDOLL Multi-Agent Security Scanner
# Copy this file to .env and fill in your API keys

# OpenAI API Key (required for LLM-based adaptive planning)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# LLM Studio / OpenAI-compatible endpoint (recommended for LOCAL LLM)
#
# IMPORTANT (Docker): DO NOT use your LAN IP (it changes). Use host.docker.internal.
# - Windows/macOS Docker Desktop: host.docker.internal works out-of-the-box.
# - Linux: docker-compose.yml should include host-gateway mapping.
#
# LM Studio should be running an OpenAI-compatible server on port 1234.
# Example (Docker):
#   LLM_BASE_URL=http://host.docker.internal:1234/v1
# Example (no Docker, same machine):
#   LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_BASE_URL=http://host.docker.internal:1234/v1

# LLM model name used by the planner/client (must match what LM Studio exposes)
# Example: qwen2.5-7b-instruct, llama-3.1-8b-instruct, etc.
LLM_MODEL=qwen2.5-7b-instruct

# Provider selector (kept as 'openai' for OpenAI-compatible endpoints like LM Studio)
LLM_PROVIDER=openai

# Adaptive Execution Mode (controls tool selection strategy)
# Options:
#   - off: Run ALL tools (maximum detection, no LLM optimization)
#   - conservative: LLM selects 2-3 tools (maximum efficiency)
#   - balanced: Run CRITICAL tools + LLM selection (default, recommended)
#   - aggressive: Run CRITICAL+HIGH tools + LLM selection (maximum coverage)
ADAPTIVE_MODE=aggressive

# Database (already configured in docker-compose.yml)
# DATABASE_URL=postgresql+psycopg://rajdoll:rajdoll@db:5432/rajdoll

# Redis (already configured in docker-compose.yml)
# REDIS_URL=redis://redis:6379/0
