from mcp.server.fastmcp import FastMCP
import asyncio
import httpx
import re
import json
import os
from typing import Dict, Any, List, Optional
from urllib.parse import urlparse

mcp = FastMCP("client-side-testing")

# --- Helpers ---
async def sh(cmd: str, timeout: int = 90) -> str:
    """Run a shell command in a Linux container using bash -lc (no WSL)."""
    proc = await asyncio.create_subprocess_exec(
        "bash", "-lc", cmd,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
    )
    try:
        out, err = await asyncio.wait_for(proc.communicate(), timeout)
        return out.decode("utf-8", errors="ignore").strip()
    except asyncio.TimeoutError:
        return "Error: Command timed out"
    except Exception as e:
        return f"Error: {e}"

# --- Tools (Revisi, Peningkatan & Baru) ---

@mcp.tool()
async def find_vulnerable_js_libraries(url: str) -> Dict[str, Any]:
    """
    [BARU] Uses retire.js to find vulnerable JavaScript libraries.
    Requires `npm install -g retire`.
    """
    try:
        # Menjalankan retire.js dengan output JSON
        cmd = f"retire --url {url} --outputformat json --jspath {urlparse(url).netloc}"
        output = await sh(cmd, 120)
        
        # Output retire.js mungkin mengandung teks lain, kita cari JSON-nya
        json_match = re.search(r'\{"version":.*?\}', output, re.DOTALL)
        if not json_match:
            return {"status": "success", "data": {"findings": [], "message": "Retire.js did not find any libraries or vulnerabilities."}}

        results = json.loads(json_match.group(0))
        return {"status": "success", "data": results}
    except Exception as e:
        return {"status": "error", "message": str(e)}

@mcp.tool()
async def analyze_csp(url: str) -> Dict[str, Any]:
    """
    [PENINGKATAN] Fetches and analyzes the Content-Security-Policy header for common weaknesses.
    """
    try:
        async with httpx.AsyncClient(verify=False) as client:
            resp = await client.get(url)
        
        csp = resp.headers.get("content-security-policy", "")
        if not csp:
            return {"status": "success", "data": {"vulnerable": True, "message": "CSP header is missing."}}

        findings = []
        if "'unsafe-inline'" in csp:
            findings.append("Allows 'unsafe-inline', increasing XSS risk.")
        if "'unsafe-eval'" in csp:
            findings.append("Allows 'unsafe-eval', which can be dangerous.")
        if re.search(r"script-src\s+[^;]*\*", csp):
            findings.append("Uses a wildcard (*) in script-src, which is overly permissive.")
        if not re.search(r"object-src", csp):
             findings.append("Missing 'object-src' directive, defaulting to permissive settings (potential object injection). Consider setting to 'none'.")

        return {"status": "success", "data": {"policy": csp, "weaknesses_found": findings}}
    except Exception as e:
        return {"status": "error", "message": str(e)}

@mcp.tool()
async def test_dom_xss(url: str) -> Dict[str, Any]:
    """
    [REVISI] Uses kxss to find DOM XSS sinks and parses its output.
    """
    try:
        cmd = f"kxss '{url}'"
        output = await sh(cmd, 60)
        
        # Parsing manual output kxss (karena tidak ada output JSON native)
        sinks = re.findall(r"Sink found: (.*?)\n", output)
        payloads = re.findall(r"PoC: (.*?)\n", output)

        return {"status": "success", "data": {"sinks": sinks, "poc_payloads": payloads}}
    except Exception as e:
        return {"status": "error", "message": str(e)}

@mcp.tool()
async def check_sri_hashes(url: str) -> Dict[str, Any]:
    """
    [BARU] Checks for missing Subresource Integrity (SRI) hashes on external scripts and links.
    """
    try:
        async with httpx.AsyncClient(verify=False) as client:
            resp = await client.get(url)
        content = resp.text
        
        # Cari semua tag <script src="..."> dan <link href="...">
        scripts = re.findall(r'<script .*?src=["\'](https?://[^"\']+)["\'].*?>', content, re.I)
        links = re.findall(r'<link .*?href=["\'](https?://[^"\']+)["\'].*?>', content, re.I)
        
        missing_sri = []
        for tag, resources in [("script", scripts), ("link", links)]:
            for resource_url in resources:
                # Periksa apakah tag yang sama memiliki atribut 'integrity'
                # Ini adalah simplifikasi; regex yang lebih kompleks diperlukan untuk akurasi 100%
                full_tag_match = re.search(f'<(?:script|link) .*? (?:src|href)=["\']{re.escape(resource_url)}["\'].*?>', content, re.I)
                if full_tag_match and "integrity=" not in full_tag_match.group(0):
                    missing_sri.append({"tag": tag, "resource_url": resource_url})

        return {"status": "success", "data": {"missing_sri_on_external_resources": missing_sri}}
    except Exception as e:
        return {"status": "error", "message": str(e)}

@mcp.tool()
async def test_clickjacking(url: str) -> Dict[str, Any]:
    """
    [REVISI] Checks for missing X-Frame-Options or CSP frame-ancestors headers.
    """
    try:
        async with httpx.AsyncClient(verify=False) as client:
            resp = await client.get(url)
        
        xfo_header = resp.headers.get("x-frame-options", "Not Set")
        csp_header = resp.headers.get("content-security-policy", "")
        
        is_protected_by_xfo = xfo_header.lower() in ["deny", "sameorigin"]
        is_protected_by_csp = "frame-ancestors" in csp_header
        
        is_vulnerable = not (is_protected_by_xfo or is_protected_by_csp)

        return {"status": "success", "data": {
            "vulnerable": is_vulnerable,
            "x_frame_options": xfo_header,
            "csp_frame_ancestors_present": is_protected_by_csp
        }}
    except Exception as e:
        return {"status": "error", "message": str(e)}

@mcp.tool()
async def test_websockets_origin(ws_url: str) -> Dict[str, Any]:
    """
    [REVISI] Checks if a WebSocket server validates the Origin header.
    """
    try:
        import websockets # Pastikan library ini terinstal
        malicious_origin = "https://evil-domain.com"
        async with websockets.connect(ws_url, extra_headers={"Origin": malicious_origin}) as ws:
            # Jika koneksi berhasil, berarti origin tidak divalidasi
            return {"status": "success", "data": {"vulnerable": True, "description": f"Successfully connected to WebSocket from a malicious origin ({malicious_origin})."}}
    except websockets.exceptions.InvalidStatusCode as e:
        # Status seperti 403 Forbidden adalah pertanda baik
        return {"status": "success", "data": {"vulnerable": False, "description": f"Connection failed with status {e.status_code}, origin check likely enforced."}}
    except Exception as e:
        # Error lain mungkin juga menandakan perlindungan
        return {"status": "success", "data": {"vulnerable": False, "description": f"Connection failed, origin check may be enforced. Error: {str(e)}"}}


@mcp.tool()
async def get_manual_checklist(topic: str) -> Dict[str, Any]:
    """
    [KONSOLIDASI] Provides checklists for manual client-side testing.
    Topics: 'web_messaging', 'dom_interaction'
    """
    checklists = {
        "web_messaging": [
            "Use browser developer tools to monitor `postMessage` events.",
            "Identify where messages are received (`window.addEventListener('message', ...)`).",
            "Check if the event handler validates the `event.origin` against a trusted whitelist before processing data.",
            "Check if the received `event.data` is treated as untrusted and properly sanitized before being used in sinks like `innerHTML` or `eval`."
        ],
        "dom_interaction": [
            "Identify all DOM sinks in the JavaScript code (e.g., `innerHTML`, `document.write`).",
            "Trace data from sources (e.g., `location.hash`, `document.referrer`) to these sinks.",
            "Manually craft payloads to test if data from sources can execute code when it reaches a sink."
        ]
    }
    if topic in checklists:
        return {"status": "success", "data": {"topic": topic, "checklist": checklists[topic]}}
    else:
        return {"status": "error", "message": f"Invalid topic. Available topics: {list(checklists.keys())}"}

# --- Prompt ---
@mcp.prompt()
def setup_prompt(domainname: str) -> str:
    return f"""
You are an expert penetration tester specialising in **client-side vulnerabilities**.
Your mission is to evaluate **{domainname}** in accordance with OWASP WSTG 4.11.

**Strategy & Primary Objectives:**
1.  **Analyze Dependencies & Policies (Highest Priority):**
    - Use `find_vulnerable_js_libraries` to immediately check for known CVEs in third-party code. This is often the most critical finding.
    - Use `analyze_csp` to check for weaknesses in the Content Security Policy.

2.  **Test for Common Vulnerabilities:**
    - Use `test_clickjacking` to ensure the application cannot be framed.
    - Use `test_dom_xss` to probe for DOM-based XSS sinks.
    - Use `check_sri_hashes` to ensure external resources are loaded securely.

3.  **Test Communication Channels:**
    - Use `test_websockets_origin` on any discovered WebSocket URLs (`wss://...`) to check for origin validation flaws.
    - Consult the `get_manual_checklist` for `web_messaging` if the application uses `postMessage`.

Devise a plan starting with the highest priority objectives. Analyze each JSON result, adapt your tactics based on findings, and report clearly.
"""

if __name__ == "__main__":
    mcp.run(transport="stdio")